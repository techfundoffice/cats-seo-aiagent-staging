# Operator-facing list of required secrets for cats-seo-aiagent-cloudflare.
# Set on the live worker via `wrangler secret put <NAME>` (NOT in this file).
# Set in GitHub Actions via repo Settings → Secrets and variables → Actions.
#
# Note: this file documents what to set; it is NOT loaded by the worker or
# by wrangler. The worker reads from Cloudflare's secret store; the indexer
# CI workflow reads from GitHub Actions secrets.

# ──────────────────────────────────────────────────────────────────────────
# Semantic codebase search (Milvus / OpenAI)
# Used by the runtime `searchCodebase()` in src/lib/codebase-search.ts AND
# by the CI indexer in scripts/index-codebase.mjs. Same Milvus collection
# is written by CI and queried by the worker.
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
MILVUS_ADDRESS=https://in03-xxx.zilliz.com   # Zilliz Cloud cluster endpoint
MILVUS_TOKEN=...                              # Zilliz Cloud bearer token
# MILVUS_COLLECTION=code_chunks               # Optional; defaults to "code_chunks"
