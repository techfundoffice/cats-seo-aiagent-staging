{
  "$schema": "https://json.schemastore.org/claude-code-mcp-servers",
  "_comment": "Project-scoped MCP servers. Claude Code auto-connects these for any session opened in this repo. Values with ${...} are resolved from the environment; .claude/secrets.env exports COMPOSIO_API_KEY via the bootstrap documented in CLAUDE.md. This replaces the Rube MCP that sunsets 2026-05-15.",
  "mcpServers": {
    "composio": {
      "type": "http",
      "url": "https://connect.composio.dev/mcp",
      "headers": {
        "x-consumer-api-key": "${COMPOSIO_API_KEY}"
      }
    },
    "cats-skills": {
      "type": "http",
      "url": "https://cats-seo-aiagent.webmaster-bc8.workers.dev/mcp"
    },
    "n8n-mcp": {
      "type": "http",
      "url": "https://n8n.srv828840.hstgr.cloud/mcp-server/http",
      "headers": {
        "Authorization": "Bearer <YOUR_ACCESS_TOKEN_HERE>"
      }
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  }
}
